# Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Service
SERVICE_NAME=truth-engine
SERVICE_VERSION=0.1.0
HOST=0.0.0.0
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=truth_engine
DB_USER=truth_engine
DB_PASSWORD=truth_engine_dev
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Object Storage (MinIO)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minio_dev
S3_SECRET_KEY=minio_dev_secret
S3_BUCKET_NAME=truth-engine
S3_REGION=us-east-1
S3_USE_SSL=false

# Graph Store (disabled in A0)
GRAPH_ENABLED=false
GRAPH_HOST=localhost
GRAPH_PORT=7687

# Vector Store (disabled in A0)
VECTOR_ENABLED=false
VECTOR_HOST=localhost
VECTOR_PORT=6333

# API
API_PREFIX=/api/v1
DOCS_URL=/docs

# Tracing
ENABLE_TRACING=true
TRACE_SAMPLE_RATE=1.0
